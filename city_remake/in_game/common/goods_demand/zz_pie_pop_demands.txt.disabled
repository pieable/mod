			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	paper = {
		value = 1
	
		if = {
			limit = {
				location.owner ?= {
					has_variable = por_printing_ordinances
					has_reform = government_reform:por_ordinances
				}
			}
			multiply = 2
		}
	
		multiply = {
			value = pop_literacy
			divide = 100 # value goes from 0 to 100
			desc = "POP_DEMAND_LITERACY"
		}

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	books = {
		value = 1
		if = {
			limit = {
				location.owner ?= {
					has_embraced_institution = institution:printing_press
				}
			}
			multiply = {
				value = 1.2
				desc = "POP_DEMAND_PRINTING_PRESS"
			}
		}
		multiply = {
			value = pop_literacy
			divide = 100 # value goes from 0 to 100
			desc = "POP_DEMAND_LITERACY"
		}
		

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	weaponry  = {
		value = 1
		
		
		if = {
			limit = {
				OR = {
					pop_type = pop_type:peasants
					pop_type = pop_type:laborers
				}
				and = {
					exists = owner
					owner.modifier:peasants_allowed_weapons = no
				}
			}
			
			
			multiply = {
				value = 0
				desc = "POP_DEMAND_PEASANTSNO_WEAPONS"
			}
		}

		
		
		if = {	#non-violent
			limit = { religion = religion:jain }
			multiply = {
				value = 0
				desc = "POP_DEMAND_JAIN"
			}
		}

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}


	salt  = {
		value = 1
		
		location = {
			if = {
				limit = { location_max_winter_level = none }
				multiply = {
					value = 0.75
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = mild }
				multiply = {
					value = 1
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = normal }
				multiply = {
					value = 1.2
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = severe }
				multiply = {
					value = 2.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
		}
	}

