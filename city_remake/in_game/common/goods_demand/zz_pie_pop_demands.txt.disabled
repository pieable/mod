	fine_cloth = {
		value = 1

		if = {
			limit = {
				pop_type = pop_type:clergy
				religion = religion:anglican
				location.owner ?= { has_variable = anglican_vestments }
			}
			
			multiply = {
				value = 2
				desc = "POP_DEMAND_CLERGY"
			}
		}

		

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_low_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	cloth = {
		value = 1
	

		location = {
			if = {
				limit = { location_max_winter_level = none }
				multiply = {
					value = 0.5
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = mild }
				multiply = {
					value = 1.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = normal }
				multiply = {
