##############################################################
# Replaces vanilla pop_demand to add PIE local wealth consumption.
# Base needs stay intact; market access only releases extra wealth demand.
##############################################################

##############################################################
# This is a special demands, as it has a hardcoded tag
#
# code also checks for scriptvalue from the pop scope
#
# This scales with the demands in the goods scripted per pop_type
#
############################################################

REPLACE:pop_demand = {

	#########################
	# Alcohol
	#########################
	wine = {
		value = 1
		if = {
			limit = {
				religion = {
					OR = {
						this = religion:jain
						this = religion:sikhism
						group = religion_group:muslim
					}
				}
			}
			multiply = {
				value = 0
				desc = "POP_DEMAND_RELIGION_FORBIDS"
			}
		}

		#Some Cultures have preferences
		if = {
			limit = {
				#Andeans favor "Chicha" that is a beer
				culture = { has_culture_group = culture_group:andean_group }
			}
			multiply = {
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
				value = 0.5
			}
		}

		if = {
			limit = {
				#Japanese favor "Sake" that is a liquor
				culture = { has_culture_group = culture_group:japanese_group }
			}
			multiply = {
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
				value = 0.5
			}
		}

		if = {
			limit = {
				location.region = {
					OR = {
						this = region:iberia_region
						this = region:italy_region
						this = region:balkan_region
					}
				}
			}
			multiply = {
				value = 2
				desc = "POP_DEMAND_MEDITERRANEAN"
			}
		}

		if = {
			limit = { 
				location.sub_continent = sub_continent:south_asia
			}
			multiply = {
				value = 0.6
				desc = "POP_DEMAND_INDIA"
			}
		}

		# some poptypes wants more...

		if = {
			limit = { 
				pop_type = pop_type:clergy
				religion = {
					OR = {
						this = religion:shinto # rice wine
						group = {
							OR = {
								this = religion_group:christian
								this = religion_group:israelite_group
							}
						}
					}
				}
			}
			
			multiply = {
				value = 10
				desc = "POP_DEMAND_RITUAL_WINE"
			}
		}
		if = {
			limit = { #Baltics prefer mead (wine)
				culture = { has_culture_group = culture_group:baltic_group }
			}
			multiply = {
				value = 1.2
				desc = "POP_DEMAND_BALTIC"
			}
		}
		

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	liquor = {
		value = 1
		if = {
			limit = {
				religion = {
					OR = {
						this = religion:jain
						this = religion:sikhism
						group = religion_group:muslim
					}
				}
			}
			multiply = {
				value = 0
				desc = "POP_DEMAND_RELIGION_FORBIDS"
			}
		}




		#Some Cultures have preferences
		if = {
			limit = {
				#Andeans favor "Chicha" that is a beer
				culture = { has_culture_group = culture_group:andean_group }
			}
			multiply = {
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
				value = 0.5
			}
		}

		if = {
			limit = {
				#Japanese favor "Sake" that is a liquor
				culture = { has_culture_group = culture_group:japanese_group }
			}
			multiply = {
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
				value = 2
			}
		}

		if = {
			limit = { 
				location.region = {
					OR = {
						this = region:iberia_region
						this = region:italy_region
						this = region:balkan_region
					}
				}
			}
			multiply = {
				value = 0.5
				desc = "POP_DEMAND_MEDITERRANEAN"
			}
		}
		
		if = {
			limit = { 
				location.region = {
					OR = {
						this = region:scandinavian_region
						this = region:ural_region
						this = region:russian_region
					}
				}
			}
			multiply = {
				value = 2
				desc = "POP_DEMAND_NORDIC"
			}
		}

		if = {
			limit = { #Baltics prefer mead (wine)
				culture = { has_culture_group = culture_group:baltic_group }
			}
			multiply = {
				value = 0.8
				desc = "POP_DEMAND_BALTIC"
			}
		}

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	beer = {
		value = 1
		if = {
			limit = {
				religion = {
					OR = {
						this = religion:jain
						this = religion:sikhism
						group = religion_group:muslim
					}
				}
			}
			multiply = {
				value = 0
				desc = "POP_DEMAND_RELIGION_FORBIDS"
			}
		}

		#Some Cultures have preferences
		if = {
			limit = {
				#Andeans favor "Chicha" that is a beer
				culture = { has_culture_group = culture_group:andean_group }
			}
			multiply = {
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
				value = 2
			}
		}
		if = {
			limit = {
				#Japanese favor "Sake" that is a liquor
				culture = { has_culture_group = culture_group:japanese_group }
			}
			multiply = {
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
				value = 0
			}
		}

		if = {
			limit = { 
				location.region = {
					OR = {
						this = region:iberia_region
						this = region:italy_region
						this = region:balkan_region
					}
				}
			}
			multiply = {
				value = 0.5
				desc = "POP_DEMAND_MEDITERRANEAN"
			}
		}

		if = {
			limit = { #Baltics prefer mead (wine)
				culture = { has_culture_group = culture_group:baltic_group }
			}
			multiply = {
				value = 0.8
				desc = "POP_DEMAND_BALTIC"
			}
		}

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	############################
	# Raw Materials
	############################
	fur = {
		value = 1
		location = {
			if = {
				limit = { location_max_winter_level = none }
				multiply = {
					value = 0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = mild }
				multiply = {
					value = 0.5
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = normal }
				multiply = {
					value = 1.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = severe }
				multiply = {
					value = 2.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
		}

		if = {	#non-violent
			limit = { religion = religion:jain }
			multiply = {
				value = 0
				desc = "POP_DEMAND_JAIN"
			}
		}

		if = {
			limit = { location = { topography = mountains }
			}
			multiply = {
				value = 1.1
				desc = "POP_DEMAND_TOPOGRAPHY_MOUNTAINS"
			}
		}


		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	beeswax = {
		value = 1

		location = {
			if = {
				limit = {
					OR = {
						location_max_winter_level = none
						location_max_winter_level = mild
					}
				}
				multiply = {
					value = 0.5
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = normal }
				multiply = {
					value = 1.2
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = severe }
				multiply = {
					value = 2.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
		}


		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}


	lumber = {
		value = 1


		location = {
			if = {
				limit = { location_max_winter_level = none }
				multiply = {
					value = 0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = mild }
				multiply = {
					value = 0.5
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = normal }
				multiply = {
					value = 1.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = severe }
				multiply = {
					value = 2.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
		}

		if = {
			limit = { 
				location = { topography = mountains }
			}
			multiply = {
				value = 1.2
				desc = "POP_DEMAND_TOPOGRAPHY_MOUNTAINS"
			}
		}
		
	}

	coal = {
		value = 1

		location = {
			if = {
				limit = { location_max_winter_level = none }
				multiply = {
					value = 0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = mild }
				multiply = {
					value = 0.5
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = normal }
				multiply = {
					value = 1.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
			else_if = {
				limit = { location_max_winter_level = severe }
				multiply = {
					value = 2.0
					desc = "POP_DEMAND_CLIMATE_MAX_WINTER_LEVEL"
				}
			}
		}

		if = {
			limit = { location = { topography = mountains }
			}
			multiply = {
				value = 1.2
				desc = "POP_DEMAND_TOPOGRAPHY_MOUNTAINS"
			}
		}

	}


	pearls  = {
		value = 1
		#some cultures have preferences
		if = {
			limit = {
				location.sub_continent = sub_continent:south_asia
			}
			multiply = {
				value = 2
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
			}
		}
		
		

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_low_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	amber  = {
		value = 1

		if = {
			limit = {
				location.market ?= { produced_in_market:amber <= 0 } 
			}
			
			multiply = {
				value = 0.5
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
			}
		}
		if = {
			limit = {
				location.region = {
					OR = {
						this = region:scandinavian_region
						this = region:north_german_region
						this = region:baltic_region
					}
				}
			}
			multiply = {
				value = 1.5
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
			}
		}

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_low_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	silver = {
		value = 1
		if = {
			limit = {
				exists = owner
			}
			multiply = {
				value = 1
				add = owner.modifier:global_pop_silver_demand
			}
		}
		

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_low_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	goods_gold = {
		value = 1

		#Some Cultures have preferences
		if = {
			limit = {
				culture = { has_culture_group = culture_group:andean_group }
			}
			multiply = {
				desc = "POP_DEMAND_CULTURAL_PREFERENCES"
				value = 2
			}
		}


		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_low_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	ivory = {
		value = 1

		if = {
			limit = {
				pop_type = pop_type:nobles 
				location.sub_continent = sub_continent:south_asia
			}
			multiply = {
				value = 1.2
				desc = "POP_DEMAND_NOBLES_INDIAN"
			}
		}
		if = {
			limit = { religion = religion:jain }
			multiply = {
				value = 0
				desc = "POP_DEMAND_JAIN"
			}
		}


		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_medium_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	incense = {
		value = 1

		if = {
			limit = {
				pop_type = pop_type:clergy
				OR = {
					religion = religion:miaphysite
					religion = religion:orthodox
					religion = religion:catholic
				}
			}
			multiply = {
				value = 2
				desc = "POP_DEMAND_CLERGY"
			}
		}

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_low_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
	
	gems = {
		value = 1

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_low_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	marble = {
		value = 1

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_high_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}
		
	horses = {
		value = 1

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_high_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	elephants = {
		value = 1
		if = {
			limit = {
				location.sub_continent != sub_continent:south_asia
				location.region != region:indochina_region
			}
			
			multiply = {
				value = 0
				desc = "POP_DEMAND_NOBLES_NOT_HERE"
			}
		}

		# PIE: local wealth creates extra consumption; market access only limits that extra part.
		multiply = {
			value = pie_pop_consumption_high_scale
			desc = "PIE_POP_DEMAND_LOCAL_WEALTH"
		}
	}

	medicaments = {
		value = 1

		if = {#Coca leaf usage in all society
			limit = {
				culture = { has_culture_group = culture_group:andean_group }
			}
			
			multiply = {
				value = 4
				desc = "POP_DEMAND_ANDEAN_COCA_LEAF"
			}
		}


		#Some Religions have preferences
		if = {
			limit = {
				#Coca leaf usage as sacrifice
				religion.group = religion_group:folk_peruvian_group
				pop_type = pop_type:clergy
			}
			multiply = {
				desc = "POP_DEMAND_ANDEAN_COCA_LEAF_CLERGY"
				value = 2.0
			}
