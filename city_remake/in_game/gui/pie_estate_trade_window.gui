window = {
	name = "pie_estate_trade_window"
	size = { 600 1000 }
	parentanchor = center
	movable = yes
	allow_outside = yes
	visible = "[GetPlayer.MakeScope.Var('pie_et_window_open').IsSet]"
	layer = windows_layer

	using = bg_main_inner_alt

	fixedgridbox = {
		ignore_layout = yes
		size = { 1 1 }
		addcolumn = 1
		addrow = 1
		alwaystransparent = yes
		alpha = 0
		datamodel = "[GetPlayer.MakeScope.GetList('pie_et_mapmode_trigger')]"

		item = {
			widget = {
				size = { 1 1 }
				datacontext = "[GetMapMode('pie_estate_trade_land')]"

				state = {
					name = pie_et_open_trade_mapmode
					trigger_on_create = yes
					duration = 0.01
					on_start = "[MapMode.SetMapMode]"
					on_finish = "[MapMode.SetMapMode]"
				}
			}
		}
	}

	fixedgridbox = {
		ignore_layout = yes
		size = { 1 1 }
		addcolumn = 1
		addrow = 1
		alwaystransparent = yes
		alpha = 0
		datamodel = "[GetPlayer.MakeScope.GetList('pie_et_project_mapmode_trigger')]"

		item = {
			widget = {
				size = { 1 1 }
				datacontext = "[GetMapMode('pie_estate_urbanization_projects')]"

				state = {
					name = pie_et_open_project_mapmode
					trigger_on_create = yes
					duration = 0.01
					on_start = "[MapMode.SetMapMode]"
				}
			}
		}
	}

	fixedgridbox = {
		ignore_layout = yes
		size = { 1 1 }
		addcolumn = 1
		addrow = 1
		alwaystransparent = yes
		alpha = 0
		datamodel = "[GetPlayer.MakeScope.GetList('pie_et_default_mapmode_trigger')]"

		item = {
			widget = {
				size = { 1 1 }
				datacontext = "[GetMapMode('political')]"

				state = {
					name = pie_et_open_default_mapmode
					trigger_on_create = yes
					duration = 0.01
					on_start = "[MapMode.SetMapMode]"
				}
			}
		}
	}

	fixedgridbox = {
		ignore_layout = yes
		size = { 1 1 }
		addcolumn = 1
		addrow = 1
		alwaystransparent = yes
		alpha = 0
		datamodel = "[GetPlayer.MakeScope.GetList('pie_et_sell_land_selector_trigger')]"

		item = {
			widget = {
				size = { 1 1 }
				datacontext = "[GetGenericAction('pie_et_select_sell_land_from_map')]"

				state = {
					name = pie_et_restart_sell_land_selector
					trigger_on_create = yes
					duration = 0.05
					on_finish = "[PerformGenericAction(GenericAction.Self)]"
					on_finish = "[GetScriptedGui('pie_et_sgui_clear_land_selector_triggers').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
				}
			}
		}
	}

	fixedgridbox = {
		ignore_layout = yes
		size = { 1 1 }
		addcolumn = 1
		addrow = 1
		alwaystransparent = yes
		alpha = 0
		datamodel = "[GetPlayer.MakeScope.GetList('pie_et_grant_unregistered_land_selector_trigger')]"

		item = {
			widget = {
				size = { 1 1 }
				datacontext = "[GetGenericAction('pie_et_select_grant_unregistered_land_from_map')]"

				state = {
					name = pie_et_restart_grant_unregistered_land_selector
					trigger_on_create = yes
					duration = 0.05
					on_finish = "[PerformGenericAction(GenericAction.Self)]"
					on_finish = "[GetScriptedGui('pie_et_sgui_clear_land_selector_triggers').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
				}
			}
		}
	}

	fixedgridbox = {
		ignore_layout = yes
		size = { 1 1 }
		addcolumn = 1
		addrow = 1
		alwaystransparent = yes
		alpha = 0
		datamodel = "[GetPlayer.MakeScope.GetList('pie_et_buy_land_selector_trigger')]"

		item = {
			widget = {
				size = { 1 1 }
				datacontext = "[GetGenericAction('pie_et_select_buy_land_from_map')]"

				state = {
					name = pie_et_restart_buy_land_selector
					trigger_on_create = yes
					duration = 0.05
					on_finish = "[PerformGenericAction(GenericAction.Self)]"
					on_finish = "[GetScriptedGui('pie_et_sgui_clear_land_selector_triggers').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
				}
			}
		}
	}

	vbox = {
		using = layoutpolicy_expanding
		allow_outside = yes
		margin = { 8 8 }
		spacing = 6

		widget = {
			layoutpolicy_horizontal = expanding
			size = { -1 38 }

			background = {
				using = tile_background_squared_texture
				modify_texture = {
					using = color_default_brown_texture
				}
			}

			widget = {
				ignore_layout = yes
				size = { 38 38 }
				position = { 0 0 }
				button_close_alt = {
				tooltip = "pie_gui_generic_button_tt"
					parentanchor = center
					size = { 30 30 }
					blockoverride "close_properties" {}
					blockoverride "close_onclick" {
						onclick = "[GetScriptedGui('pie_et_sgui_close_window').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
					}
					blockoverride "close_inputaction" {
						input_action = "close_window"
						use_global_input_instance = yes
					}
				}
			}

			text_single = {
				ignore_layout = yes
				size = { 100% 38 }
				parentanchor = hcenter|vcenter
				widgetanchor = hcenter|vcenter
				align = center|vcenter
				text = "pie_estate_trade_title"
				fontsize = 24
				default_format = "#yellow_titles"
			}
		}

		vbox = {
			using = layoutpolicy_expanding
			using = window_main_tabs_margin_alt
			allow_outside = yes
			spacing = 7

			widget = {
				layoutpolicy_horizontal = expanding
				size = { -1 64 }
				allow_outside = yes
				using = bg_market_card
				using = bg_cabinet_card_frame

				widget = {
					ignore_layout = yes
					parentanchor = left|vcenter
					size = { 110 100% }
					datacontext = "[Player]"

					country_flag_mid = {
						parentanchor = center
						size = { 78 48 }
					}
				}

				vbox = {
					ignore_layout = yes
					parentanchor = center
					size = { 330 54 }
					spacing = 3

					text_single = {
						layoutpolicy_horizontal = expanding
						size = { -1 22 }
						autoresize = no
						align = center|vcenter
						text = "pie_estate_trade_header_desc"
						fontsize = 14
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						size = { -1 28 }

						expand = {}

						widget = {
							size = { 104 28 }
							using = bg_number_container_bckg
							tooltip = "pie_estate_trade_acceptance_tt"

							hbox = {
								parentanchor = center
								spacing = 5

								icon = {
									size = { 20 20 }
									texture = "gfx/interface/icons/flat_icons/declare_war/peace_score.dds"
								}

								text_single = {
									size = { 42 22 }
									autoresize = no
									align = center|vcenter
									visible = "[GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value'), '(CFixedPoint)0')]"
									raw_text = "#P [GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value')|0]#!"
								}

								text_single = {
									size = { 42 22 }
									autoresize = no
									align = center|vcenter
									visible = "[LessThan_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value'), '(CFixedPoint)0')]"
									raw_text = "#N [GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value')|0]#!"
								}
							}
						}

						expand = {}
					}
				}

				widget = {
					ignore_layout = yes
					parentanchor = right|vcenter
					size = { 86 100% }

					widget = {
						parentanchor = center
						size = { 56 48 }
						using = bg_main_inner_notabs_alt

						icon = {
							visible = "[GetPlayer.MakeScope.Var('pie_et_estate_nobles').IsSet]"
							parentanchor = center
							size = { 30 30 }
							texture = "gfx/interface/icons/estates/nobles_estate.dds"
						}

						icon = {
							visible = "[GetPlayer.MakeScope.Var('pie_et_estate_clergy').IsSet]"
							parentanchor = center
							size = { 30 30 }
							texture = "gfx/interface/icons/estates/clergy_estate.dds"
						}

						icon = {
							visible = "[GetPlayer.MakeScope.Var('pie_et_estate_burghers').IsSet]"
							parentanchor = center
							size = { 30 30 }
							texture = "gfx/interface/icons/estates/burghers_estate.dds"
						}
					}
				}

			}

			widget = {
				layoutpolicy_horizontal = expanding
				size = { -1 78 }
				using = bg_main_inner_notabs_alt

				vbox = {
					parentanchor = center
					size = { 100% 74 }
					margin = { 12 0 }
					spacing = 4

					hbox = {
						layoutpolicy_horizontal = expanding
						size = { -1 35 }
						spacing = 6

						button_regular = {
							size = { 35 35 }
							tooltip = "pie_estate_trade_select_nobles_tt"
							onclick = "[GetScriptedGui('pie_et_sgui_select_nobles').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							down = "[GetPlayer.MakeScope.Var('pie_et_estate_nobles').IsSet]"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/estates/nobles_estate.dds"
							}
						}

						button_regular = {
							size = { 35 35 }
							tooltip = "pie_estate_trade_select_clergy_tt"
							onclick = "[GetScriptedGui('pie_et_sgui_select_clergy').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							down = "[GetPlayer.MakeScope.Var('pie_et_estate_clergy').IsSet]"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/estates/clergy_estate.dds"
							}
						}

						button_regular = {
							size = { 35 35 }
							tooltip = "pie_estate_trade_select_burghers_tt"
							onclick = "[GetScriptedGui('pie_et_sgui_select_burghers').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							down = "[GetPlayer.MakeScope.Var('pie_et_estate_burghers').IsSet]"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/estates/burghers_estate.dds"
							}
						}

						expand = {}
					}

					hbox = {
						layoutpolicy_horizontal = expanding
						size = { -1 35 }
						spacing = 6

						button_regular = {
							size = { 35 35 }
							tooltip = "pie_estate_trade_category_land_tt"
							onclick = "[GetScriptedGui('pie_et_sgui_select_land').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							down = "[GetPlayer.MakeScope.Var('pie_et_category_land').IsSet]"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/peace_treaty/seize_land_treaty.dds"
							}
						}

						button_regular = {
							size = { 35 35 }
							tooltip = "pie_estate_trade_category_project_tt"
							onclick = "[GetScriptedGui('pie_et_sgui_select_project').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							down = "[GetPlayer.MakeScope.Var('pie_et_category_project').IsSet]"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/flat_icons/building_panel/build.dds"
							}
						}

						button_regular = {
							size = { 35 35 }
							tooltip = "pie_estate_trade_category_privilege_tt"
							onclick = "[GetScriptedGui('pie_et_sgui_select_privilege').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							down = "[GetPlayer.MakeScope.Var('pie_et_category_privilege').IsSet]"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/flat_icons/privilege.dds"
							}
						}

						button_regular = {
							size = { 35 35 }
							tooltip = "pie_estate_trade_category_other_tt"
							onclick = "[GetScriptedGui('pie_et_sgui_select_other').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							down = "[GetPlayer.MakeScope.Var('pie_et_category_other').IsSet]"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/peace_treaty/other_treaty.dds"
							}
						}

						expand = {}

						button_regular = {
							size = { 35 35 }
							onclick = "[GetScriptedGui('pie_et_sgui_autogenerate_terms').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							tooltip = "pie_estate_trade_auto_terms_tt"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/peace_treaty/demand_treaty.dds"
							}
						}

						button_regular = {
							size = { 35 35 }
							onclick = "[GetScriptedGui('pie_et_sgui_clear_terms').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
							tooltip = "pie_estate_trade_clear_terms_tt"

							icon = {
								parentanchor = center
								size = { 24 24 }
								texture = "gfx/interface/icons/text_icons/trigger_no.dds"
							}
						}
					}
				}
			}

			widget = {
				layoutpolicy_horizontal = expanding
				layoutpolicy_vertical = expanding
				size = { -1 470 }
				using = bg_main_inner_notabs_alt

				hbox = {
					layoutpolicy_horizontal = expanding
					layoutpolicy_vertical = expanding
					margin = { 12 10 }

					expand = {}

					scrollarea = {
						layoutpolicy_horizontal = expanding
						layoutpolicy_vertical = expanding
						minimumsize = { 480 -1 }
						maximumsize = { 520 -1 }
						scrollbarpolicy_horizontal = always_off
						scrollbarpolicy_vertical = as_needed
						autoresizeviewport = yes

						viewportwidget = {
							widget = {
								scissor = yes
							}
						}

						scrollbar_vertical = {
							using = Scrollbar_Vertical
						}

						scrollwidget = {
							vbox = {
								layoutpolicy_horizontal = expanding
								spacing = 4
								ignoreinvisible = yes

								vbox = {
									visible = "[Or(GetPlayer.MakeScope.Var('pie_et_category_land').IsSet, And(Not(GetPlayer.MakeScope.Var('pie_et_category_project').IsSet), And(Not(GetPlayer.MakeScope.Var('pie_et_category_privilege').IsSet), Not(GetPlayer.MakeScope.Var('pie_et_category_other').IsSet))))]"
									layoutpolicy_horizontal = expanding
									spacing = 4

									button_regular = {
								layoutpolicy_horizontal = expanding
								size = { -1 42 }
								onclick = "[GetScriptedGui('pie_et_sgui_toggle_sell_land_group').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								down = "[Or(GetPlayer.MakeScope.Var('pie_et_land_sell_open').IsSet, GreaterThan_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_selected_sell_land_count'), '(CFixedPoint)0'))]"
								tooltip = "pie_estate_trade_land_map_pick_sell_desc"

								hbox = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									size = { 100% 100% }
									margin = { 10 0 }
									spacing = 8

									icon = {
										size = { 24 24 }
										texture = "gfx/interface/icons/map_modes/locations.dds"
									}

									text_single = {
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										size = { -1 -1 }
										autoresize = no
										align = left|vcenter
										text = "pie_estate_trade_land_sell_group"
									}

									text_single = {
										layoutpolicy_vertical = expanding
										size = { 48 -1 }
										autoresize = no
										align = right|vcenter
										raw_text = "#P [GetPlayer.MakeScope.ScriptValue('pie_et_selected_sell_land_count')|0]#!"
									}
								}
							}

									button_regular = {
								layoutpolicy_horizontal = expanding
								size = { -1 42 }
								onclick = "[GetScriptedGui('pie_et_sgui_toggle_grant_unregistered_land_group').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								down = "[Or(GetPlayer.MakeScope.Var('pie_et_land_grant_unregistered_open').IsSet, GreaterThan_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_selected_grant_unregistered_land_count'), '(CFixedPoint)0'))]"
								tooltip = "pie_estate_trade_land_map_pick_grant_unregistered_desc"

								hbox = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									size = { 100% 100% }
									margin = { 10 0 }
									spacing = 8

									icon = {
										size = { 24 24 }
										texture = "gfx/interface/icons/map_modes/locations.dds"
									}

									text_single = {
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										size = { -1 -1 }
										autoresize = no
										align = left|vcenter
										text = "pie_estate_trade_land_grant_unregistered_group"
									}

									text_single = {
										layoutpolicy_vertical = expanding
										size = { 48 -1 }
										autoresize = no
										align = right|vcenter
										raw_text = "#P [GetPlayer.MakeScope.ScriptValue('pie_et_selected_grant_unregistered_land_count')|0]#!"
									}
								}
							}

									button_regular = {
								layoutpolicy_horizontal = expanding
								size = { -1 42 }
								onclick = "[GetScriptedGui('pie_et_sgui_toggle_buy_land_group').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								down = "[Or(GetPlayer.MakeScope.Var('pie_et_land_buy_open').IsSet, GreaterThan_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_selected_buy_land_count'), '(CFixedPoint)0'))]"
								tooltip = "pie_estate_trade_land_map_pick_buy_desc"

								hbox = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									size = { 100% 100% }
									margin = { 10 0 }
									spacing = 8

									icon = {
										size = { 24 24 }
										texture = "gfx/interface/icons/map_modes/locations.dds"
									}

									text_single = {
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										size = { -1 -1 }
										autoresize = no
										align = left|vcenter
										text = "pie_estate_trade_land_buy_group"
									}

									text_single = {
										layoutpolicy_vertical = expanding
										size = { 48 -1 }
										autoresize = no
										align = right|vcenter
										raw_text = "#N [GetPlayer.MakeScope.ScriptValue('pie_et_selected_buy_land_count')|0]#!"
									}
								}
							}

								}

						vbox = {
							visible = "[GetPlayer.MakeScope.Var('pie_et_category_other').IsSet]"
							layoutpolicy_horizontal = expanding
							spacing = 4

							button_regular = {
								visible = "[Not(GetPlayer.MakeScope.Var('pie_et_term_estate_funds_project').IsSet)]"
								layoutpolicy_horizontal = expanding
								size = { -1 42 }
								onclick = "[GetScriptedGui('pie_et_sgui_toggle_estate_funds_project').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								down = "[GetPlayer.MakeScope.Var('pie_et_term_estate_funds_project').IsSet]"
								tooltip = "pie_estate_trade_term_estate_funds_project_tt"

								hbox = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									size = { 100% 100% }
									margin = { 10 0 }
									spacing = 8

									widget = {
										size = { 24 -1 }

										checkbox_diamond_alt = {
										tooltip = "pie_gui_generic_button_tt"
											parentanchor = center
											checked = "[GetPlayer.MakeScope.Var('pie_et_term_estate_funds_project').IsSet]"
											onclick = "[GetScriptedGui('pie_et_sgui_toggle_estate_funds_project').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
										}
									}

									widget = {
										size = { 24 -1 }

										icon = {
											parentanchor = center
											size = { 24 24 }
											texture = "gfx/interface/icons/peace_treaty/increase_gold.dds"
										}
									}

									text_single = {
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										size = { -1 -1 }
										autoresize = no
										align = left|vcenter
										text = "pie_estate_trade_term_estate_funds_project"
									}

									text_single = {
										layoutpolicy_vertical = expanding
										size = { 48 -1 }
										autoresize = no
										align = right|vcenter
										raw_text = "#N [GetPlayer.MakeScope.ScriptValue('pie_et_estate_funds_project_acceptance')|0]#!"
									}
								}
							}

							button_regular = {
								visible = "[Not(GetPlayer.MakeScope.Var('pie_et_term_crown_grants_rights').IsSet)]"
								layoutpolicy_horizontal = expanding
								size = { -1 42 }
								onclick = "[GetScriptedGui('pie_et_sgui_toggle_crown_grants_rights').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								down = "[GetPlayer.MakeScope.Var('pie_et_term_crown_grants_rights').IsSet]"
								tooltip = "pie_estate_trade_term_crown_grants_rights_tt"

								hbox = {
									layoutpolicy_horizontal = expanding
									layoutpolicy_vertical = expanding
									size = { 100% 100% }
									margin = { 10 0 }
									spacing = 8

									widget = {
										size = { 24 -1 }

										checkbox_diamond_alt = {
										tooltip = "pie_gui_generic_button_tt"
											parentanchor = center
											checked = "[GetPlayer.MakeScope.Var('pie_et_term_crown_grants_rights').IsSet]"
											onclick = "[GetScriptedGui('pie_et_sgui_toggle_crown_grants_rights').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
										}
									}

									widget = {
										size = { 24 -1 }

										icon = {
											parentanchor = center
											size = { 24 24 }
											texture = "gfx/interface/icons/peace_treaty/seize_land_treaty.dds"
										}
									}

									text_single = {
										layoutpolicy_horizontal = expanding
										layoutpolicy_vertical = expanding
										size = { -1 -1 }
										autoresize = no
										align = left|vcenter
										text = "pie_estate_trade_term_crown_grants_rights"
									}

									text_single = {
										layoutpolicy_vertical = expanding
										size = { 48 -1 }
										autoresize = no
										align = right|vcenter
										raw_text = "#P +[GetPlayer.MakeScope.ScriptValue('pie_et_crown_grants_rights_acceptance')|0]#!"
									}
								}
							}

							button_regular = {
								visible = "[Not(GetPlayer.MakeScope.Var('pie_et_term_royal_credit_pledge').IsSet)]"
