								size = { -1 42 }
								onclick = "[GetScriptedGui('pie_et_sgui_toggle_reduce_privilege').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								down = "[GetPlayer.MakeScope.Var('pie_et_term_reduce_privilege').IsSet]"
								tooltip = "pie_estate_trade_term_reduce_privilege_tt"

