										checkbox_diamond_alt = {
											parentanchor = center
											checked = "[GetPlayer.MakeScope.Var('pie_et_term_repay_principal').IsSet]"
											onclick = "[GetScriptedGui('pie_et_sgui_toggle_repay_principal').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
										}
									}

									widget = {
										size = { 24 100% }

										icon = {
											parentanchor = center
											size = { 24 24 }
											texture = "gfx/interface/icons/resources/gold.dds"
