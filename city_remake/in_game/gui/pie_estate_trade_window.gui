											parentanchor = center
											checked = "[GetPlayer.MakeScope.Var('pie_et_term_reduce_privilege').IsSet]"
											onclick = "[GetScriptedGui('pie_et_sgui_toggle_reduce_privilege').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
