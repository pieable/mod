										size = { 24 100% }

										checkbox_diamond_alt = {
											parentanchor = center
											checked = "[GetPlayer.MakeScope.Var('pie_et_term_crown_grants_rights').IsSet]"
											onclick = "[GetScriptedGui('pie_et_sgui_toggle_crown_grants_rights').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
										}
									}

									widget = {
										size = { 24 100% }

										icon = {
											parentanchor = center
