									}
									onrightclick = "[GetScriptedGui('pie_et_sgui_gold_dec_big').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								}
							}

							widget = {
								layoutpolicy_vertical = expanding
								size = { 104 100% }

								widget = {
									parentanchor = center
