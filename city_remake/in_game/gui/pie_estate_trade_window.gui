										size = { 48 100% }
										autoresize = no
										align = right|vcenter
										raw_text = "#P +20#!"
									}
								}
							}

						}

						vbox = {
							visible = "[GetPlayer.MakeScope.Var('pie_et_category_privilege').IsSet]"
							layoutpolicy_horizontal = expanding
							spacing = 4

							button_regular = {
								layoutpolicy_horizontal = expanding
								size = { -1 42 }
								onclick = "[GetScriptedGui('pie_et_sgui_toggle_grant_privilege').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								down = "[GetPlayer.MakeScope.Var('pie_et_term_grant_privilege').IsSet]"
