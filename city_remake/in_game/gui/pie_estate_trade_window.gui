						hbox = {
							layoutpolicy_vertical = expanding
							size = { 316 100% }
							spacing = 6

							text_single = {
								layoutpolicy_vertical = expanding
								size = { 58 100% }
								autoresize = no
								align = right|vcenter
								text = "pie_estate_trade_interest"
								default_format = "#yellow_titles"
							}

							widget = {
								layoutpolicy_vertical = expanding
								size = { 24 100% }

								button_minus = {
									parentanchor = center
									size = { 24 24 }
									enabled = "[GreaterThan_CFixedPoint(GetPlayer.MakeScope.Var('pie_et_gold').GetValue, '(CFixedPoint)0')]"
									onclick = "[GetScriptedGui('pie_et_sgui_interest_dec').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								}
							}

							widget = {
								layoutpolicy_vertical = expanding
								size = { 68 100% }

								widget = {
									parentanchor = center
									size = { 68 30 }
									using = bg_number_container_bckg
									tooltip = "pie_estate_trade_interest_tt"

									text_single = {
										parentanchor = center
										size = { 100% 100% }
										autoresize = no
										align = center|vcenter
										raw_text = "[GetPlayer.MakeScope.Var('pie_et_interest').GetValue|%0]"
									}
								}
							}

							widget = {
								layoutpolicy_vertical = expanding
								size = { 24 100% }

								button_plus = {
									parentanchor = center
									size = { 24 24 }
									enabled = "[GreaterThan_CFixedPoint(GetPlayer.MakeScope.Var('pie_et_gold').GetValue, '(CFixedPoint)0')]"
									onclick = "[GetScriptedGui('pie_et_sgui_interest_inc').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
								}
							}

							widget = {
								layoutpolicy_vertical = expanding
								size = { 118 100% }

								widget = {
									parentanchor = center
									size = { 118 30 }
									using = bg_number_container_bckg
									tooltip = "pie_estate_trade_monthly_interest_tt"

									hbox = {
										parentanchor = center
										size = { 100% 100% }
										spacing = 4

										text_single = {
											size = { 38 24 }
											autoresize = no
											align = right|vcenter
											text = "pie_estate_trade_monthly_interest_short"
										}

										text_single = {
											size = { 64 24 }
											autoresize = no
											align = left|vcenter
											raw_text = "[GetPlayer.MakeScope.ScriptValue('pie_et_monthly_interest_preview')|2] @gold!"
										}
									}
								}
							}
						}
					}
				}

				hbox = {
					layoutpolicy_horizontal = expanding
					size = { -1 24 }
					spacing = 8

					text_single = {
						parentanchor = vcenter
						layoutpolicy_vertical = expanding
						size = { -1 100% }
						autoresize = no
						align = left|vcenter
						text = "pie_estate_trade_existing_debt"
						default_format = "#yellow_titles"
					}

					text_single = {
						parentanchor = vcenter
						layoutpolicy_vertical = expanding
						size = { -1 100% }
						autoresize = no
						align = left|vcenter
						raw_text = "[GetPlayer.MakeScope.ScriptValue('pie_et_selected_estate_debt')|0] @gold!"
					}

					expand = {}

					text_single = {
						parentanchor = vcenter
						layoutpolicy_vertical = expanding
						size = { -1 100% }
						autoresize = no
						align = right|vcenter
						text = "pie_estate_trade_existing_interest"
						default_format = "#yellow_titles"
					}

					text_single = {
						parentanchor = vcenter
						layoutpolicy_vertical = expanding
						size = { -1 100% }
						autoresize = no
						align = right|vcenter
						raw_text = "[GetPlayer.MakeScope.ScriptValue('pie_et_selected_estate_interest')|%0]"
					}
				}

				button_regular = {
					layoutpolicy_horizontal = expanding
					size = { -1 44 }
					enabled = "[GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value'), '(CFixedPoint)0')]"
					onclick = "[GetScriptedGui('pie_et_sgui_accept_trade').Execute(GuiScope.SetRoot(GetPlayer.MakeScope).End)]"
					tooltip = "pie_estate_trade_send_tt"

					hbox = {
						parentanchor = center
						spacing = 8

						icon = {
							parentanchor = vcenter
							visible = "[GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value'), '(CFixedPoint)0')]"
							size = { 28 28 }
							texture = "gfx/interface/icons/text_icons/trigger_yes.dds"
						}

						icon = {
							parentanchor = vcenter
							visible = "[LessThan_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value'), '(CFixedPoint)0')]"
							size = { 28 28 }
							texture = "gfx/interface/icons/text_icons/trigger_no.dds"
						}

						text_single = {
							parentanchor = vcenter
							size = { -1 28 }
							autoresize = no
							align = center|vcenter
							text = "pie_estate_trade_send"
							default_format = "#yellow_titles"
						}

						text_single = {
							parentanchor = vcenter
							size = { 48 28 }
							autoresize = no
							align = right|vcenter
							visible = "[GreaterThanOrEqualTo_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value'), '(CFixedPoint)0')]"
							raw_text = "#P [GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value')|0]#!"
						}

						text_single = {
							parentanchor = vcenter
							size = { 48 28 }
							autoresize = no
							align = right|vcenter
							visible = "[LessThan_CFixedPoint(GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value'), '(CFixedPoint)0')]"
							raw_text = "#N [GetPlayer.MakeScope.ScriptValue('pie_et_acceptance_value')|0]#!"
						}
					}
				}
			}
		}
	}

